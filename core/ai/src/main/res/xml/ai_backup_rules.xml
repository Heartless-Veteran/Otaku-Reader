<?xml version="1.0" encoding="utf-8"?>
<full-backup-content xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="MissingPrefix">
    <!--
        AI Module Backup Rules
        
        These rules explicitly exclude all files related to AI configuration
        and API key storage from cloud backups. This is a defense-in-depth
        measure alongside android:allowBackup="false" at the app level.
        
        EXCLUDED (never backed up):
        - DataStore preferences files containing API keys
        - EncryptedSharedPreferences files
        - AI configuration files
        
        SECURITY NOTE: Even though the API keys are encrypted at rest using
        AES-256, we never back them up to prevent:
        1. Key migration attacks (backup restore to different device)
        2. Cloud storage compromise exposure
        3. Accidental disclosure in backup archives
    -->

    <!-- Exclude DataStore files containing API keys -->
    <exclude
        domain="sharedpref"
        path="secure_api_keys.preferences_pb" />
    
    <exclude
        domain="sharedpref"
        path="ai_config.preferences_pb" />

    <!-- Exclude EncryptedSharedPreferences -->
    <exclude
        domain="sharedpref"
        path="secure_api_keys_encrypted.xml" />

    <!-- Exclude all files in the DataStore directory -->
    <exclude
        domain="file"
        path="datastore/" />

    <!-- Exclude any backup of encrypted key material -->
    <exclude
        domain="file"
        path="no_backup/" />

</full-backup-content>
